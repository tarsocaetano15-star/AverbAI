<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Monitor de Navios PRO - Frequência Total</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet"/>
<style>
  :root {
    --bg: #0a0f1e; --surface: #111827; --surface2: #1a2236;
    --accent: #00d4ff; --accent2: #f59e0b; --text: #e2e8f0;
    --muted: #64748b; --border: rgba(255,255,255,0.08);
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); color: var(--text); font-family: 'DM Sans', sans-serif; padding: 2rem 1rem; }
  .wrapper { max-width: 500px; margin: 0 auto; }
  .card { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 1.25rem; margin-bottom: 1rem; }
  h1 { font-family: 'Space Mono', monospace; font-size: 18px; color: var(--accent); margin-bottom: 1rem; text-align: center; }
  
  /* Inputs e Botões */
  input, select, button { width: 100%; padding: 10px; margin: 5px 0; border-radius: 8px; border: 1px solid var(--border); background: var(--surface2); color: white; }
  button { background: var(--accent); color: #0a0f1e; font-weight: bold; cursor: pointer; border: none; }
  button.sec { background: transparent; border: 1px solid var(--accent); color: var(--accent); }
  
  /* Grid de Frequência */
  .freq-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px; margin: 10px 0; }
  .fq-btn { font-size: 11px; padding: 8px; background: var(--surface2); cursor: pointer; border: 1px solid var(--border); border-radius: 6px; color: var(--muted); }
  .fq-btn.on { border-color: var(--accent); color: var(--accent); background: rgba(0,212,255,0.1); }
  
  /* Lista de Navios */
  .ship-item { background: var(--surface2); padding: 10px; border-radius: 8px; margin-top: 5px; display: flex; justify-content: space-between; align-items: center; }
  .btn-del { width: auto; background: transparent; color: #ef4444; padding: 0 10px; }

  #toasts { position: fixed; bottom: 20px; right: 20px; z-index: 999; }
  .toast { background: #1e293b; border-left: 4px solid var(--accent); padding: 12px; border-radius: 8px; margin-top: 10px; min-width: 200px; }
</style>
</head>
<body>

<div class="wrapper">
  <h1>🚢 MONITOR DE NAVIOS v3</h1>

  <!-- Diagnóstico e Permissão -->
  <div class="card">
    <div id="diag-text" style="font-size: 12px; margin-bottom: 10px; color: var(--muted);">Verificando permissões...</div>
    <button id="btn-perm" onclick="solicitarPermissao()">🔔 Liberar Notificações no Windows</button>
  </div>

  <!-- Cadastro -->
  <div class="card">
    <input type="text" id="ship-name" placeholder="Nome do Navio (ex: MSC OSCAR)">
    <input type="text" id="ship-port" placeholder="Porto (ex: Santos)">
    <button onclick="addShip()">+ Adicionar Navio</button>
    <div id="list-container" style="margin-top: 10px;"></div>
  </div>

  <!-- Frequência de Quantas Vezes ao Dia -->
  <div class="card">
    <div style="font-size: 13px; color: var(--accent); margin-bottom: 10px;">⏱️ Frequência de Verificação</div>
    <div class="freq-grid">
      <button class="fq-btn" onclick="setFreq(15)">15 min</button>
      <button class="fq-btn" onclick="setFreq(60)">1 hora</button>
      <button class="fq-btn" onclick="setFreq(720)">12 horas</button>
    </div>
    <input type="range" id="freq-slider" min="1" max="1440" value="1440" oninput="updateSliderLabel(this.value)">
    <div id="slider-label" style="text-align: center; font-size: 12px; color: var(--muted);">Frequência: 1 vez ao dia (1440 min)</div>
  </div>

  <!-- Alarme Fixo -->
  <div class="card">
    <div style="font-size: 13px; color: var(--accent); margin-bottom: 5px;">⏰ Horário de Verificação Fixa</div>
    <input type="time" id="alarm-time" value="09:00">
    <button onclick="startMonitor()" id="btn-start" style="margin-top: 10px;">▶ INICIAR MONITORAMENTO</button>
    <button onclick="testarNotificacao()" class="sec" style="margin-top: 8px;">🧪 Testar Alerta Agora</button>
  </div>
</div>

<div id="toasts"></div>

<script>
  let ships = [];
  let monitorInterval = null;
  let lastFixedAlarmDate = '';
  let lastFreqExecutionTime = 0; // Para controlar o intervalo do slider

  // --- DOCUMENTAÇÃO: PERMISSÕES ---
  async function solicitarPermissao() {
    if (!("Notification" in window)) return alert("Navegador não suporta notificações.");
    const p = await Notification.requestPermission();
    atualizarStatus();
    if (p === "granted") {
        new Notification("🚢 Sistema Ativado", { body: "Você receberá os alertas aqui, mesmo no Excel." });
    }
  }

  function atualizarStatus() {
    const diag = document.getElementById('diag-text');
    const btn = document.getElementById('btn-perm');
    if (Notification.permission === "granted") {
      diag.innerHTML = "✅ Notificações Ativadas para Windows/Sistema.";
      btn.style.display = "none";
    } else {
      diag.innerHTML = "⚠️ Notificações bloqueadas. Clique abaixo para liberar.";
    }
  }

  // --- DOCUMENTAÇÃO: GESTÃO DE NAVIOS ---
  function addShip() {
    const name = document.getElementById('ship-name').value;
    const port = document.getElementById('ship-port').value;
    if (!name) return;
    ships.push({ id: Date.now(), name, port });
    document.getElementById('ship-name').value = "";
    renderList();
  }

  function renderList() {
    const container = document.getElementById('list-container');
    container.innerHTML = ships.map(s => `
      <div class="ship-item">
        <span><b>${s.name}</b> (${s.port})</span>
        <button class="btn-del" onclick="removeShip(${s.id})">×</button>
      </div>
    `).join('');
  }

  function removeShip(id) {
    ships = ships.filter(s => s.id !== id);
    renderList();
  }

  // --- DOCUMENTAÇÃO: CONTROLE DE FREQUÊNCIA ---
  function setFreq(min) {
    document.getElementById('freq-slider').value = min;
    updateSliderLabel(min);
  }

  function updateSliderLabel(val) {
    let texto = val + " minutos";
    if (val >= 60 && val < 1440) texto = Math.round(val/60) + " hora(s)";
    if (val == 1440) texto = "1 vez ao dia (24h)";
    document.getElementById('slider-label').innerText = "Frequência: " + texto;
  }

  // --- DOCUMENTAÇÃO: O MOTOR DO MONITOR ---
  function startMonitor() {
    if (ships.length === 0) return alert("Adicione ao menos um navio.");
    if (Notification.permission !== "granted") solicitarPermissao();

    document.getElementById('btn-start').innerText = "🟢 MONITORANDO...";
    document.getElementById('btn-start').disabled = true;

    // Loop de Verificação (Roda a cada 1 segundo)
    monitorInterval = setInterval(() => {
      const agora = new Date();
      const horaAtual = agora.getHours().toString().padStart(2, '0') + ":" + agora.getMinutes().toString().padStart(2, '0');
      const dataHoje = agora.toDateString();

      // 1. Lógica do Alarme Fixo
      const horaFixa = document.getElementById('alarm-time').value;
      if (horaAtual === horaFixa && lastFixedAlarmDate !== dataHoje) {
        dispararAlerta("VERIFICAÇÃO AGENDADA");
        lastFixedAlarmDate = dataHoje;
      }

      // 2. Lógica da Frequência (Slider)
      const freqMinutos = parseInt(document.getElementById('freq-slider').value);
      const agoraMs = agora.getTime();
      const intervaloMs = freqMinutos * 60 * 1000;

      if (agoraMs - lastFreqExecutionTime >= intervaloMs) {
        if (lastFreqExecutionTime !== 0) { // Não dispara no primeiro segundo que ligar
             dispararAlerta("VERIFICAÇÃO PERIÓDICA");
        }
        lastFreqExecutionTime = agoraMs;
      }

    }, 1000);
  }

  function dispararAlerta(tipo) {
    ships.forEach(s => {
      const titulo = `🚢 ${tipo}: ${s.name}`;
      const corpo = `Destino/Porto: ${s.port}`;

      // Notificação que aparece sobre o Excel
      if (Notification.permission === "granted") {
        new Notification(titulo, {
          body: corpo,
          requireInteraction: true, // Fica na tela até você clicar
          icon: 'https://cdn-icons-png.flaticon.com/512/2040/2040061.png'
        });
      }
      
      // Alerta visual no navegador
      const t = document.createElement('div');
      t.className = 'toast';
      t.innerHTML = `<b>${titulo}</b><br>${corpo}`;
      document.getElementById('toasts').appendChild(t);
      setTimeout(() => t.remove(), 10000);
    });
  }

  function testarNotificacao() {
    if(ships.length === 0) ships.push({name: "NAVIO TESTE", port: "PORTO TESTE"});
    dispararAlerta("TESTE DE SISTEMA");
  }

  window.onload = atualizarStatus;
</script>
</body>
</html>
