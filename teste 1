<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Monitor de Navios PRO - Individual</title>
    <link rel="stylesheet" href="style.css">
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
</head>
<body>
    <div class="wrapper">
        <header>
            <div class="header-top"><span>🚢</span><h1>MONITOR DE NAVIOS</h1></div>
            <div class="subtitle">Controle Individual D+6</div>
        </header>

        <div class="card">
            <div id="diag-text">Verificando permissões...</div>
            <button id="btn-perm" onclick="solicitarPermissao()">🔔 Liberar Notificações no Sistema</button>
        </div>

        <div class="card">
            <div class="card-title">Novo Monitoramento (Alerta D+6)</div>
            <input type="text" id="ship-name" placeholder="Nome do Navio">
            <input type="text" id="ship-port" placeholder="Porto">
            <div class="label-accent" style="margin-top:10px">Horário do Alerta:</div>
            <input type="time" id="alarm-time" value="09:00">
            <button onclick="addShip()" style="margin-top:10px">+ Iniciar Monitoramento</button>
        </div>

        <div class="card">
            <div class="label-accent">⏱️ Frequência de Verificação do Sistema</div>
            <div class="freq-grid">
                <button class="fq-btn" onclick="setFreq(1, this)">1 min</button>
                <button class="fq-btn" onclick="setFreq(15, this)">15 min</button>
                <button class="fq-btn" onclick="setFreq(60, this)">1 h</button>
                <button class="fq-btn on" onclick="setFreq(1440, this)">24 h</button>
            </div>
            <input type="hidden" id="freq-val" value="1440">
        </div>

        <div id="list-container">
            <!-- Navios aparecerão aqui com botões individuais -->
        </div>
    </div>

    <div id="toasts"></div>
    <script src="script.js"></script>
</body>
</html>
