/**
 * DOCUMENTAÇÃO: Este ficheiro não morre quando fechas a aba.
 */
self.addEventListener('message', (event) => {
    if (event.data.type === 'ALERTA') {
        self.registration.showNotification("🚢 Monitor de Navios", {
            body: event.data.msg,
            icon: "https://cdn-icons-png.flaticon.com/512/2040/2040061.png",
            requireInteraction: true
        });
    }
});
